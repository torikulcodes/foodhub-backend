{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",

    "module": "esnext",
    "moduleResolution": "bundler",

    "target": "ES2023",
    "types": ["node"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true
  },

  "include": ["src/**/*", "src/server.ts"],
  "exclude": ["node_modules", "dist"]
}
