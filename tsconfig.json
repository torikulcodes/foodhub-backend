{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "target": "ES2023",
    "types": ["node"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}